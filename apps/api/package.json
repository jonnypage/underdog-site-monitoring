{
  "name": "@app/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm codegen && tsx watch src/server.ts",
    "build": "pnpm codegen && tsc -p tsconfig.json && cp src/graphql/schema.graphql dist/graphql/schema.graphql",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "codegen": "graphql-codegen --config codegen.ts"
  },
  "dependencies": {
    "@app/db": "workspace:*",
    "@fastify/cors": "10.0.1",
    "@graphql-tools/schema": "10.0.18",
    "bcryptjs": "2.4.3",
    "dotenv": "16.4.7",
    "fastify": "5.8.5",
    "graphql": "16.10.0",
    "graphql-yoga": "5.10.10",
    "kysely": "0.28.15",
    "next-auth": "5.0.0-beta.25",
    "resend": "4.1.2",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "5.0.4",
    "@graphql-codegen/typescript": "4.1.3",
    "@graphql-codegen/typescript-resolvers": "4.4.2",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "22.10.7",
    "tsx": "4.19.2",
    "typescript": "5.7.3"
  }
}
