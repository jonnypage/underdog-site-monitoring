# Copy to `.env` in this directory for local API dev.
# Local Postgres or Railway Postgres connection string.
DATABASE_URL="postgres://user:password@host/db"

# Optional: max PostgreSQL connections per process (default 10). For a single API instance, 2–4 is usually enough.
# PG_POOL_MAX=3

AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3333"
NEXTAUTH_URL="http://localhost:3333"

NEXT_PUBLIC_API_URL="http://localhost:4000"
WEB_ORIGIN="http://localhost:3333"
PORT=4000

RESEND_API_KEY=""
ALERT_FROM_EMAIL="alerts@example.com"
COOLDOWN_MINUTES=45
