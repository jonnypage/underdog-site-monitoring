# Local development: pnpm runs each workspace from its own directory, so dotenv and Next.js
# load env from package cwd. Keep the same values in all three:
#   packages/db/.env          (migrate, seed)
#   apps/api/.env             (API / pnpm dev)
#   apps/web/.env.local       (Next.js; use Railway public DB URL from your laptop)
# Committed templates: packages/db/.env.example, apps/api/.env.example, apps/web/.env.example

# Local Postgres or Railway Postgres connection string.
DATABASE_URL="postgres://user:password@host/db"

# Optional: cap node-postgres pool size (default 10). On Railway, the API process rarely needs many
# concurrent DB connections; try 2–4 on the API service to trim client memory a bit.
# PG_POOL_MAX=3

AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3333"
NEXTAUTH_URL="http://localhost:3333"

NEXT_PUBLIC_API_URL="http://localhost:4000"
# Optional: Google Maps key for the web app — enable Maps Embed API (site detail) and Maps JavaScript API (admin draggable pin).
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY=""
WEB_ORIGIN="http://localhost:3333"
PORT=4000

RESEND_API_KEY=""
ALERT_FROM_EMAIL="alerts@example.com"
COOLDOWN_MINUTES=45
