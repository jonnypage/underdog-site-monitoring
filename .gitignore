# Dependencies
node_modules/
.pnp/
.pnp.*

# pnpm local state/cache (keep pnpm-lock.yaml committed)
.pnpm-store/
.pnpm-state/
pnpm-debug.log*

# Logs and diagnostics
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Environment files (pnpm runs migrate/seed/api/web from package cwd; each needs its own file)
.env
.env.*
!.env.example
apps/*/.env
apps/*/.env.*
packages/*/.env
packages/*/.env.*
# Allow committed templates named `.env.example` under apps/ and packages/
!apps/**/.env.example
!packages/**/.env.example

# Build outputs
dist/
build/
out/
.next/
apps/*/dist/
apps/*/build/
apps/*/out/
apps/*/.next/
packages/*/dist/
packages/*/build/

# Generated GraphQL output
apps/api/src/graphql/generated.ts
apps/web/lib/gql/generated/

# Caches
.cache/
.turbo/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo

# Coverage
coverage/
*.lcov
.nyc_output/

# Runtime files
pids/
*.pid
*.pid.lock
*.seed

# Local deployment/tooling state
.vercel/
.netlify/
.railway/
.serverless/

# PlatformIO firmware build artefacts (the merged firmware.bin is copied into
# apps/web/public/firmware/<board>/ by firmware/scripts/copy-binaries.sh and
# committed there for the in-browser installer).
firmware/**/.pio/
firmware/**/.pioenvs/
firmware/**/.piolibdeps/

# OS/editor noise
.DS_Store
Thumbs.db
.node_repl_history
