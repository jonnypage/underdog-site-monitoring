{
  "name": "@app/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/client.js",
  "types": "./dist/client.d.ts",
  "exports": {
    ".": {
      "types": "./src/client.ts",
      "import": "./src/client.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "2.4.3",
    "dotenv": "16.4.7",
    "kysely": "0.28.15",
    "pg": "8.13.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/pg": "8.11.10",
    "tsx": "4.19.2",
    "typescript": "5.7.3"
  }
}
