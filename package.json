{
  "name": "underdog-site-monitoring",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @app/api --filter @app/web dev",
    "build": "pnpm -r build",
    "build:api": "pnpm --filter @app/api build",
    "build:web": "pnpm --filter @app/web build",
    "start:api": "pnpm --filter @app/api start",
    "start:web": "pnpm --filter @app/web start",
    "typecheck": "pnpm -r typecheck",
    "codegen": "pnpm --filter @app/api codegen && pnpm --filter @app/web codegen",
    "migrate": "pnpm --filter @app/db migrate",
    "migrate:deploy": "pnpm --filter @app/db migrate",
    "seed": "pnpm --filter @app/db seed"
  },
  "devDependencies": {
    "@types/node": "22.10.7",
    "typescript": "5.7.3"
  }
}
